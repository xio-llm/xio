# --- Server ---
SERVER_PORT=3001
AUTH_TOKEN=
STORAGE_DIR=./storage
LOG_LEVEL=info

# --- LLM Provider ---
# Options: openai | ollama | anthropic | lmstudio
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# --- Embedding Provider ---
# Options: openai | ollama | local
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# --- Vector Database ---
# Options: chroma | pinecone | lancedb
VECTOR_DB=chroma
CHROMA_URL=http://localhost:8000
PINECONE_API_KEY=
PINECONE_INDEX=
LANCEDB_PATH=./storage/lancedb

# --- Audio Transcription ---
# Options: whisper-local | openai-whisper
WHISPER_PROVIDER=whisper-local
WHISPER_MODEL=base

# --- Agent Wallet (Solana) ---
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
WALLET_KEYPAIR_PATH=./wallet.json
WALLET_ENCRYPTION_KEY=

# --- Credits & Payments ---
CREDITS_ENABLED=false
CREDITS_PER_QUERY=1
CREDITS_PER_UPLOAD=5
SOL_PRICE_PER_CREDIT=0.001
