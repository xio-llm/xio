{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "paths": {
      "@server/*": ["./server/*"],
      "@ui/*": ["./ui/*"]
    }
  },
  "include": ["server/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
