{
  "name": "xio",
  "version": "2.1.0",
  "description": "Self-hosted workspace for interacting with your data through local LLMs",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "tsc && cp -r ui dist/ui",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint server/ --ext .ts",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.5",
    "@solana/spl-token": "^0.4.9",
    "express": "^4.21.1",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1",
    "uuid": "^11.0.5",
    "better-sqlite3": "^11.7.0",
    "openai": "^4.77.0",
    "chromadb": "^1.9.2",
    "@pinecone-database/pinecone": "^4.0.0",
    "pdf-parse": "^1.1.1",
    "mammoth": "^1.8.0",
    "csv-parse": "^5.6.0",
    "cheerio": "^1.0.0",
    "ytdl-core": "^4.11.5",
    "node-cron": "^3.0.3",
    "winston": "^3.17.0",
    "ws": "^8.18.0",
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/cors": "^2.8.17",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8",
    "eslint": "^9.17.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
